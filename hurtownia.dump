CREATE VIEW aktualny_stan_magazynu AS
SELECT
    p.nazwa,
    k.nazwa AS kategoria,
    p.cena_zakupu AS cena,
    COALESCE(m.ilosc_na_stanie, 0) AS ilosc_na_stanie
FROM
    produkty p
JOIN
    kategorie k ON p.id_kategorii = k.id_kategorii
LEFT JOIN
    magazyn m ON p.id_produktu = m.id_produktu;
    
CREATE VIEW brakujace_produkty AS
SELECT
    p.id_produktu,
    p.nazwa AS nazwa_produktu,
    COALESCE(m.ilosc_na_stanie, 0) AS ilosc_na_stanie
FROM
    produkty p
JOIN
    magazyn m ON p.id_produktu = m.id_produktu
WHERE
    COALESCE(m.ilosc_na_stanie, 0) < 20;

GRANT ALL PRIVILEGES ON ALL TABLES IN SCHEMA public TO administrator;
GRANT ALL PRIVILEGES ON ALL SEQUENCES IN SCHEMA public TO administrator;

GRANT SELECT, INSERT, UPDATE ON TABLE klienci, zamowienia TO sprzedawca;
GRANT INSERT, DELETE, UPDATE, SELECT ON TABLE dane_zamowienia TO sprzedawca;
GRANT SELECT ON TABLE produkty, kategorie TO sprzedawca;
GRANT USAGE, SELECT ON SEQUENCE klienci_id_klienta_seq, zamowienia_id_zamowienia_seq TO sprzedawca;

GRANT SELECT, INSERT, UPDATE ON TABLE dostawy, dane_dostawy TO magazynier;
GRANT SELECT ON TABLE magazyn, produkty, kategorie TO magazynier;
GRANT USAGE, SELECT ON SEQUENCE dostawy_id_dostawy_seq TO magazynier;

GRANT SELECT ON TABLE produkty, kategorie TO users;

COMMIT;
