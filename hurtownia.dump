---Funkcje---

CREATE FUNCTION AnulujZamowienie(p_id_zamowienia INTEGER)
RETURNS VOID AS $$
BEGIN
    DELETE FROM zamowienia
    WHERE id_zamowienia = p_id_zamowienia;
    
END;
$$ LANGUAGE plpgsql;



CREATE FUNCTION RejestrujDostawe(
    p_id_producenta INTEGER,
    p_id_produktow INTEGER[],
    p_ilosci INTEGER[],
    p_ceny_zakupu NUMERIC[]
)
RETURNS INTEGER AS $$ DECLARE
    id_nowa_dostawa INTEGER;
BEGIN
    INSERT INTO dostawy (id_producenta, data_dostawy)
    VALUES (p_id_producenta, CURRENT_DATE)
    RETURNING id_dostawy INTO id_nowa_dostawa;

    INSERT INTO dane_dostawy (id_dostawy, id_produktu, ilosc, cena_zakupu)
    SELECT
        id_nowa_dostawa,
        id_produktu,
        ilosc,
        cena
    FROM
        UNNEST(p_id_produktow, p_ilosci, p_ceny_zakupu) AS t(id_produktu, ilosc, cena);

    RETURN id_nowa_dostawa;
END;
$$ LANGUAGE plpgsql;




CREATE FUNCTION oblicz_cene_zamowienia(p_id_zampwienia INTEGER)
RETURNS NUMERIC(10, 2) AS $$
DECLARE
    suma_calkowita NUMERIC(10, 2);
BEGIN
    SELECT COALESCE(SUM(ilosc * cena_zakupu), 0)
    INTO suma_calkowita
    FROM dane_zamowienia
    WHERE id_zamowienia = p_id_zamowienia;

    RETURN suma_calkowita;
END;
$$ LANGUAGE plpgsql;

CREATE FUNCTION aktualizuj_cene()
RETURNS trigger AS $$
BEGIN
    IF NEW.cena_zakupu IS DISTINCT FROM OLD.cena_zakupu THEN
        UPDATE produkty
        SET cena_zakupu = NEW.cena_zakupu
        WHERE id_produktu = NEW.id_produktu;
    END IF;
    RETURN NEW;
END;
$$ LANGUAGE plpgsql;

CREATE FUNCTION dodaj_dostawe_do_magazynu()
RETURNS TRIGGER AS $$
BEGIN
    INSERT INTO magazyn (id_produktu, ilosc)
    VALUES (NEW.id_produktu, NEW.ilosc)
    
    ON CONFLICT (id_produktu) DO UPDATE SET
        ilosc = magazyn.ilosc + EXCLUDED.ilosc;

    RETURN NEW;
END;

$$ LANGUAGE plpgsql;


CREATE OR REPLACE FUNCTION sprawdz_i_pobierz_z_magazynu()
RETURNS TRIGGER AS $$
DECLARE
    aktualny_stan INTEGER;
    ilosc_do_pobrania INTEGER := 0;
BEGIN
    IF (TG_OP = 'INSERT') THEN
        ilosc_do_pobrania := NEW.ilosc;
        
    ELSIF (TG_OP = 'UPDATE') THEN
        IF NEW.ilosc > OLD.ilosc THEN
            ilosc_do_pobrania := NEW.ilosc - OLD.ilosc;
        ELSIF NEW.ilosc < OLD.ilosc THEN
            RETURN NEW;
        ELSE
            RETURN NEW;
        END IF;
    END IF;

    IF ilosc_do_pobrania <= 0 THEN
        RETURN NEW;
    END IF;

    SELECT ilosc INTO aktualny_stan
    FROM magazyn
    WHERE id_produktu = NEW.id_produktu
    FOR UPDATE;

    IF aktualny_stan IS NULL OR ilosc_do_pobrania > aktualny_stan THEN
        RAISE EXCEPTION 'Brak wystarczającej ilości towaru w magazynie (ID: %). Potrzebne: %, Dostępne: %',
                        NEW.id_produktu, ilosc_do_pobrania, COALESCE(aktualny_stan, 0);
    ELSE
        UPDATE magazyn
        SET ilosc = magazyn.ilosc - ilosc_do_pobrania
        WHERE id_produktu = NEW.id_produktu;
       
        RETURN NEW;
    END IF;
END;
$$ LANGUAGE plpgsql;

---Triggery---

CREATE TRIGGER trg_po_zmianie_ceny_dostawy
AFTER INSERT OR UPDATE OF cena_zakupu ON dane_dostawy
FOR EACH ROW
EXECUTE FUNCTION aktualizuj_cene();

CREATE TRIGGER trg_po_dodaniu_dostawy
AFTER INSERT ON dane_dostawy
FOR EACH ROW
EXECUTE FUNCTION dodaj_dostawe_do_magazynu();

CREATE TRIGGER trg_sprawdz_magazyn_przed_zamowieniem
BEFORE INSERT OR UPDATE ON dane_zamowienia
FOR EACH ROW
EXECUTE FUNCTION sprawdz_i_pobierz_z_magazynu();


---Widoki---

CREATE VIEW AktualnyStanMagazynu AS
SELECT
    p.nazwa,
    k.nazwa AS kategoria,
    p.cena_zakupu AS cena,
    
    COALESCE(m.ilosc, 0) AS ilosc
FROM
    produkty p
JOIN
    kategorie k ON p.id_kategorii = k.id_kategorii
LEFT JOIN
    magazyn m ON p.id_produktu = m.id_produktu;



CREATE VIEW BrakujaceProdukty AS
SELECT
    p.id_produktu,
    p.nazwa AS nazwa_produktu,
    COALESCE(m.ilosc, 0) AS ilosc,
    
    pr.nazwa_firmy AS producent,
    pr.email AS email_producenta,
    pr.telefon AS kontakt
    
FROM
    produkty p
JOIN
    producenci pr ON p.id_producenta = pr.id_producenta
LEFT JOIN
    magazyn m ON p.id_produktu = m.id_produktu
WHERE
    COALESCE(m.ilosc, 0) < 20;

COMMIT;
