SET statement_timeout = 0;
SET lock_timeout = 0;
SET idle_in_transaction_session_timeout = 0;
SET client_encoding = 'UTF8';
SET standard_conforming_strings = on;
SELECT pg_catalog.set_config('search_path', '', false);
SET check_function_bodies = false;
SET xmloption = content;
SET client_min_messages = warning;
SET row_security = off;

\connect postgres

DO $$
BEGIN
   -- Rola Administratora
   IF NOT EXISTS (SELECT FROM pg_catalog.pg_roles WHERE rolname = 'administrator') THEN
      CREATE ROLE administrator WITH LOGIN PASSWORD 'admin_haslo';
   END IF;
   -- Rola Sprzedawcy
   IF NOT EXISTS (SELECT FROM pg_catalog.pg_roles WHERE rolname = 'sprzedawca') THEN
      CREATE ROLE sprzedawca WITH LOGIN PASSWORD 'sprzedawca_haslo';
   END IF;
   -- Rola Magazyniera
   IF NOT EXISTS (SELECT FROM pg_catalog.pg_roles WHERE rolname = 'magazynier') THEN
      CREATE ROLE magazynier WITH LOGIN PASSWORD 'magazyn_haslo';
   END IF;
	-- Rola Users 
   IF NOT EXISTS (SELECT FROM pg_catalog.pg_roles WHERE rolname = 'users') THEN
      CREATE ROLE users WITH LOGIN PASSWORD '1234';
   END IF;
END
$$;

\connect hurtownia

BEGIN;
DROP VIEW IF EXISTS brakujace_produkty CASCADE;
DROP VIEW IF EXISTS aktualny_stan_magazynu CASCADE;
DROP TABLE IF EXISTS dane_zamowienia CASCADE;
DROP TABLE IF EXISTS dane_dostawy CASCADE;
DROP TABLE IF EXISTS magazyn CASCADE;
DROP TABLE IF EXISTS zamowienia CASCADE;
DROP TABLE IF EXISTS dostawy CASCADE;
DROP TABLE IF EXISTS produkty CASCADE;
DROP TABLE IF EXISTS kategorie CASCADE;
DROP TABLE IF EXISTS producenci CASCADE;
DROP TABLE IF EXISTS klienci CASCADE;


CREATE TABLE klienci (
    id_klienta SERIAL PRIMARY KEY,
    nazwa_firmy VARCHAR(100) NOT NULL UNIQUE,
    nip VARCHAR(15) NOT NULL UNIQUE,
    adres VARCHAR(200),
    telefon VARCHAR(20),
    email VARCHAR(100),
    czy_aktywny BOOLEAN NOT NULL DEFAULT TRUE
);

CREATE TABLE producenci (
    id_producenta SERIAL PRIMARY KEY,
    nazwa_firmy VARCHAR(100) NOT NULL UNIQUE,
    nip VARCHAR(15) NOT NULL UNIQUE, 
    adres VARCHAR(200),
    telefon VARCHAR(20),
    email VARCHAR(100),
    czy_aktywny BOOLEAN NOT NULL DEFAULT TRUE
);

CREATE TABLE kategorie (
    id_kategorii SERIAL PRIMARY KEY,
    nazwa VARCHAR(50) NOT NULL UNIQUE
);

CREATE TABLE produkty (
    id_produktu SERIAL PRIMARY KEY,
    id_kategorii INTEGER NOT NULL DEFAULT 0,
    nazwa VARCHAR(200) NOT NULL,
    cena_zakupu NUMERIC(10, 2) NOT NULL CHECK (cena_zakupu > 0),
    
    CONSTRAINT fk_kategoria
        FOREIGN KEY (id_kategorii)
        REFERENCES kategorie(id_kategorii)
        ON DELETE SET DEFAULT
);

CREATE TABLE dostawy (
    id_dostawy SERIAL PRIMARY KEY,
    id_producenta INTEGER NOT NULL,
    data_dostawy DATE NOT NULL DEFAULT CURRENT_DATE,
    nr_faktury VARCHAR(50) UNIQUE,
    
    CONSTRAINT fk_producenci 
	FOREIGN KEY (id_producenta) 
	REFERENCES producenci(id_producenta)
);

CREATE TABLE zamowienia (
    id_zamowienia SERIAL PRIMARY KEY,
    id_klienta INTEGER NOT NULL,
    data_zamowienia DATE NOT NULL DEFAULT CURRENT_DATE,
    nr_faktury VARCHAR(50) UNIQUE,
    
    CONSTRAINT fk_klienci
        FOREIGN KEY (id_klienta) 
        REFERENCES klienci(id_klienta)
);

CREATE TABLE magazyn (
    id_produktu SERIAL PRIMARY KEY,
    ilosc_na_stanie INTEGER NOT NULL DEFAULT 0 CHECK (ilosc_na_stanie >= 0),
    
    CONSTRAINT fk_magazyn_produkty 
        FOREIGN KEY (id_produktu) 
        REFERENCES produkty(id_produktu) 
);

CREATE TABLE dane_dostawy (
    id_dostawy INTEGER NOT NULL,
    id_produktu INTEGER NOT NULL,
    ilosc INTEGER NOT NULL CHECK (ilosc > 0),
    cena_dostawy DECIMAL(10,2) NOT NULL CHECK (cena_dostawy > 0),
    
    PRIMARY KEY (id_dostawy, id_produktu),
    
    CONSTRAINT fk_dostawy 
        FOREIGN KEY (id_dostawy) 
        REFERENCES dostawy(id_dostawy) 
        ON DELETE CASCADE,
        
    CONSTRAINT fk_produkty 
        FOREIGN KEY (id_produktu) 
        REFERENCES produkty(id_produktu)
);

CREATE TABLE dane_zamowienia (
    id_zamowienia INTEGER NOT NULL,
    id_produktu INTEGER NOT NULL,
    ilosc INTEGER NOT NULL CHECK (ilosc > 0),
    cena_zakupu DECIMAL(10,2) NOT NULL CHECK (cena_zakupu > 0),

    PRIMARY KEY (id_zamowienia, id_produktu),
    
    CONSTRAINT fk_zamowienia
        FOREIGN KEY (id_zamowienia) 
        REFERENCES zamowienia(id_zamowienia)
        ON DELETE CASCADE,
        
    CONSTRAINT fk_produkty
        FOREIGN KEY (id_produktu) 
        REFERENCES produkty(id_produktu)
);


CREATE OR REPLACE FUNCTION oblicz_wartosc_dostawy()
RETURNS TRIGGER AS $$
DECLARE
    v_cena_jednostkowa NUMERIC;
BEGIN
    SELECT cena_zakupu INTO v_cena_jednostkowa
    FROM produkty
    WHERE id_produktu = NEW.id_produktu;
    IF v_cena_jednostkowa IS NULL THEN
        RAISE EXCEPTION 'Nie znaleziono produktu o ID %', NEW.id_produktu;
    END IF;
    NEW.cena_dostawy := NEW.ilosc * v_cena_jednostkowa;

    RETURN NEW;
END;$$
LANGUAGE plpgsql;

CREATE TRIGGER trg_aktualizuj_wartosc_dostawy
BEFORE INSERT OR UPDATE ON dane_dostawy
FOR EACH ROW
EXECUTE FUNCTION oblicz_wartosc_dostawy();

CREATE OR REPLACE FUNCTION aktualizuj_stan_po_dostawie()
RETURNS TRIGGER AS $$
BEGIN
    UPDATE magazyn
    SET ilosc_na_stanie = ilosc_na_stanie + NEW.ilosc
    WHERE id_produktu = NEW.id_produktu;

    RETURN NEW;
END;
$$ LANGUAGE plpgsql;

CREATE TRIGGER trg_dodaj_do_magazynu
AFTER INSERT ON dane_dostawy
FOR EACH ROW
EXECUTE FUNCTION aktualizuj_stan_po_dostawie();

CREATE OR REPLACE FUNCTION aktualizuj_stan_po_zamowieniu()
RETURNS TRIGGER AS $$
DECLARE
    v_roznica_ilosci INTEGER;
BEGIN
    IF (TG_OP = 'INSERT') THEN
          v_roznica_ilosci := -NEW.ilosc;
    ELSIF (TG_OP = 'UPDATE') THEN
          v_roznica_ilosci := OLD.ilosc - NEW.ilosc;
    END IF;

    UPDATE magazyn
    SET ilosc_na_stanie = ilosc_na_stanie + v_roznica_ilosci
    WHERE id_produktu = NEW.id_produktu;

    RETURN NEW;
END;
$$ LANGUAGE plpgsql;


CREATE TRIGGER trg_odejmij_z_magazynu
AFTER INSERT OR UPDATE ON dane_zamowienia
FOR EACH ROW
EXECUTE FUNCTION aktualizuj_stan_po_zamowieniu();

CREATE OR REPLACE FUNCTION archiwizacja_klienta()
RETURNS TRIGGER AS $$
BEGIN
    UPDATE klienci
    SET czy_aktywny = FALSE
    WHERE id_klienta = OLD.id_klienta;
    RAISE NOTICE 'Nie mozna usuwac klientow. Wartosc czy_aktywny dla klienta o ID % ustawiona na FALSE', OLD.id_klienta;
    RETURN NULL;
END;
$$ LANGUAGE plpgsql;

CREATE TRIGGER trg_archiwizacja_klienta
BEFORE DELETE ON klienci
FOR EACH ROW
EXECUTE FUNCTION archiwizacja_klienta();

CREATE OR REPLACE FUNCTION archiwizacja_producenta()
RETURNS TRIGGER AS $$
BEGIN
    UPDATE producenci
    SET czy_aktywny = FALSE
    WHERE id_producenta = OLD.id_producenta;
    RAISE NOTICE 'Nie mozna usuwac producentow. Wartosc czy_aktywny dla producenta o ID % ustawiona na FALSE', OLD.id_producenta;
    RETURN NULL;
END;
$$ LANGUAGE plpgsql;

CREATE TRIGGER trg_archiwizacja_producenta
BEFORE DELETE ON producenci
FOR EACH ROW
EXECUTE FUNCTION archiwizacja_producenta();

CREATE OR REPLACE FUNCTION sprawdz_dostepnosc_produktu()
RETURNS TRIGGER AS $$
DECLARE
    v_ilosc_na_stanie INTEGER;
    v_stara_ilosc INTEGER := 0;
BEGIN
    SELECT ilosc_na_stanie INTO v_ilosc_na_stanie
    FROM magazyn
    WHERE id_produktu = NEW.id_produktu;

    IF v_ilosc_na_stanie IS NULL THEN
         RAISE EXCEPTION 'Produkt o ID % nie znajduje się w tabeli magazyn', NEW.id_produktu;
    END IF;

    IF (TG_OP = 'UPDATE') THEN
        v_stara_ilosc := OLD.ilosc;
    END IF;

    IF (v_ilosc_na_stanie + v_stara_ilosc) < NEW.ilosc THEN
        RAISE EXCEPTION 'Brak towaru. Na stanie (wliczając obecną rezerwację) dostępne jest % szt. produktu ID %. Nie można zwiększyć zamówienia do % szt.', 
                        (v_ilosc_na_stanie + v_stara_ilosc), NEW.id_produktu, NEW.ilosc;
    END IF;

    RETURN NEW;
END;
$$ LANGUAGE plpgsql;

CREATE TRIGGER trg_weryfikacja_stanu
BEFORE INSERT OR UPDATE ON dane_zamowienia
FOR EACH ROW
EXECUTE FUNCTION sprawdz_dostepnosc_produktu();

CREATE OR REPLACE FUNCTION oblicz_wartosc_zamowienia()
RETURNS TRIGGER AS $$
DECLARE
    v_cena_zakupu NUMERIC;
BEGIN
    SELECT cena_zakupu INTO v_cena_zakupu
    FROM produkty
    WHERE id_produktu = NEW.id_produktu;

    IF v_cena_zakupu IS NULL THEN
        RAISE EXCEPTION 'Nie znaleziono produktu o ID %', NEW.id_produktu;
    END IF;
    
    NEW.cena_zakupu := ROUND((NEW.ilosc * v_cena_zakupu * 1.1), 2);

    RETURN NEW;
END;
$$ LANGUAGE plpgsql;


CREATE TRIGGER trg_aktualizuj_wartosc_zamowienia
BEFORE INSERT OR UPDATE ON dane_zamowienia
FOR EACH ROW
EXECUTE FUNCTION oblicz_wartosc_zamowienia();


CREATE FUNCTION RejestrujDostawe(
    p_id_producenta INTEGER,
    p_id_produktow INTEGER[],
    p_ilosci INTEGER[],
    p_ceny_dostawy NUMERIC[]
)
RETURNS INTEGER AS $$ DECLARE
    id_nowa_dostawa INTEGER;
BEGIN
    INSERT INTO dostawy (id_producenta, data_dostawy)
    VALUES (p_id_producenta, CURRENT_DATE)
    RETURNING id_dostawy INTO id_nowa_dostawa;

    INSERT INTO dane_dostawy (id_dostawy, id_produktu, ilosc, cena_dostawy)
    SELECT
        id_nowa_dostawa,
        id_produktu,
        ilosc,
        cena
    FROM
        UNNEST(p_id_produktow, p_ilosci, p_ceny_dostawy) AS t(id_produktu, ilosc, cena);

    RETURN id_nowa_dostawa;
END;
$$ LANGUAGE plpgsql;

CREATE OR REPLACE FUNCTION bestseller_kategorii(p_nazwa_kategorii VARCHAR)
RETURNS VARCHAR AS $$
DECLARE
    v_produkt VARCHAR;
BEGIN
    SELECT p.nazwa INTO v_produkt
    FROM produkty p
    JOIN kategorie k ON p.id_kategorii = k.id_kategorii
    JOIN dane_zamowienia dz ON p.id_produktu = dz.id_produktu
    WHERE k.nazwa = p_nazwa_kategorii
    GROUP BY p.id_produktu, p.nazwa
    ORDER BY SUM(dz.ilosc) DESC
    LIMIT 1;
    
    IF v_produkt IS NULL THEN
        RETURN 'Brak danych sprzedażowych dla kategorii: ' || p_nazwa_kategorii;
    END IF;

    RETURN v_produkt;
END;
$$ LANGUAGE plpgsql;

CREATE OR REPLACE FUNCTION pobierz_wartosc_zamowienia(p_id_zamowienia INTEGER)
RETURNS NUMERIC AS $$
DECLARE
    v_suma NUMERIC(10,2);
BEGIN
    SELECT COALESCE(SUM(cena_zakupu), 0)
    INTO v_suma
    FROM dane_zamowienia
    WHERE id_zamowienia = p_id_zamowienia;

    RETURN v_suma;
END;
$$ LANGUAGE plpgsql;

CREATE OR REPLACE FUNCTION pobierz_wartosc_dostawy(p_id_dostawy INTEGER)
RETURNS NUMERIC AS $$
DECLARE
    v_suma NUMERIC(10,2);
BEGIN
    SELECT COALESCE(SUM(cena_dostawy), 0)
    INTO v_suma
    FROM dane_dostawy
    WHERE id_dostawy = p_id_dostawy;

    RETURN v_suma;
END;
$$ LANGUAGE plpgsql;

CREATE OR REPLACE PROCEDURE powtorz_zamowienie(p_stare_id_zamowienia INTEGER, p_nowy_nr_faktury VARCHAR)
AS $$
DECLARE
    v_nowe_id_zamowienia INTEGER;
    v_id_klienta INTEGER;
BEGIN
    SELECT id_klienta INTO v_id_klienta
    FROM zamowienia
    WHERE id_zamowienia = p_stare_id_zamowienia;

    IF v_id_klienta IS NULL THEN
        RAISE NOTICE 'Zamówienie źródłowe o ID % nie istnieje.', p_stare_id_zamowienia;
        RETURN;
    END IF;

    INSERT INTO zamowienia (id_klienta, data_zamowienia, nr_faktury)
    VALUES (v_id_klienta, CURRENT_DATE, p_nowy_nr_faktury)
    RETURNING id_zamowienia INTO v_nowe_id_zamowienia;

    INSERT INTO dane_zamowienia (id_zamowienia, id_produktu, ilosc, cena_zakupu)
    SELECT v_nowe_id_zamowienia, id_produktu, ilosc, 0
    FROM dane_zamowienia
    WHERE id_zamowienia = p_stare_id_zamowienia;

    RAISE NOTICE 'Utworzono nowe zamówienie nr % na podstawie zamówienia nr %.', v_nowe_id_zamowienia, p_stare_id_zamowienia;
END;
$$ LANGUAGE plpgsql;

CREATE OR REPLACE FUNCTION bilans_miesieczny(p_rok INTEGER, p_miesiac INTEGER)
RETURNS NUMERIC AS $$
DECLARE
    v_przychody NUMERIC(10,2) := 0;
    v_wydatki NUMERIC(10,2) := 0;
BEGIN
    SELECT COALESCE(SUM(dz.cena_zakupu), 0)
    INTO v_przychody
    FROM zamowienia z
    JOIN dane_zamowienia dz ON z.id_zamowienia = dz.id_zamowienia
    WHERE EXTRACT(YEAR FROM z.data_zamowienia) = p_rok
      AND EXTRACT(MONTH FROM z.data_zamowienia) = p_miesiac;

    SELECT COALESCE(SUM(dd.cena_dostawy), 0)
    INTO v_wydatki
    FROM dostawy d
    JOIN dane_dostawy dd ON d.id_dostawy = dd.id_dostawy
    WHERE EXTRACT(YEAR FROM d.data_dostawy) = p_rok
      AND EXTRACT(MONTH FROM d.data_dostawy) = p_miesiac;

    RETURN v_przychody - v_wydatki;
END;
$$ LANGUAGE plpgsql;

CREATE OR REPLACE PROCEDURE anuluj_zamowienie(p_id_zamowienia INTEGER)
AS $$
BEGIN
    IF NOT EXISTS (SELECT 1 FROM zamowienia WHERE id_zamowienia = p_id_zamowienia) THEN
        RAISE NOTICE 'Zamówienie o ID % nie istnieje.', p_id_zamowienia;
        RETURN;
    END IF;

    UPDATE magazyn m
    SET ilosc_na_stanie = m.ilosc_na_stanie + dz.ilosc
    FROM dane_zamowienia dz
    WHERE m.id_produktu = dz.id_produktu
      AND dz.id_zamowienia = p_id_zamowienia;

    DELETE FROM zamowienia 
    WHERE id_zamowienia = p_id_zamowienia;

    RAISE NOTICE 'Zamówienie nr % zostało pomyślnie anulowane. Towary wróciły na stan.', p_id_zamowienia;
END;
$$ LANGUAGE plpgsql;

