BEGIN;

-- Usuwanie tabel (zachowana kolejność)
DROP TABLE IF EXISTS dane_zamowienia;
DROP TABLE IF EXISTS dane_dostawy;
DROP TABLE IF EXISTS magazyn;
DROP TABLE IF EXISTS zamowienia;
DROP TABLE IF EXISTS dostawy;
DROP TABLE IF EXISTS produkty;
DROP TABLE IF EXISTS klienci;
DROP TABLE IF EXISTS producenci;
DROP TABLE IF EXISTS kategorie;

-- Tworzenie struktury tabel

CREATE TABLE producenci (
    id_producenta SERIAL PRIMARY KEY,
    nazwa_firmy VARCHAR(100) NOT NULL UNIQUE,
    nip VARCHAR(15) NOT NULL UNIQUE, 
    adres VARCHAR(200),
    telefon VARCHAR(20),
    email VARCHAR(100)
);

CREATE TABLE kategorie (
    id_kategorii SERIAL PRIMARY KEY,
    nazwa VARCHAR(50) NOT NULL UNIQUE
);

CREATE TABLE klienci (
    id_klienta SERIAL PRIMARY KEY,
    nazwa_firmy VARCHAR(100) NOT NULL UNIQUE,
    nip VARCHAR(15) NOT NULL UNIQUE,
    adres VARCHAR(200),
    telefon VARCHAR(20),
    email VARCHAR(100) 
);

CREATE TABLE produkty (
    id_produktu SERIAL PRIMARY KEY,
    id_producenta INTEGER NOT NULL,
    id_kategorii INTEGER NOT NULL,
    nazwa VARCHAR(200) NOT NULL,
    cena_zakupu NUMERIC(10, 2) NOT NULL CHECK (cena_zakupu > 0),
    
    CONSTRAINT fk_producent FOREIGN KEY (id_producenta) REFERENCES producenci(id_producenta) ON DELETE CASCADE,
    CONSTRAINT fk_kategoria FOREIGN KEY (id_kategorii) REFERENCES kategorie(id_kategorii) ON DELETE CASCADE
);

CREATE TABLE dostawy (
    id_dostawy SERIAL PRIMARY KEY,
    id_producenta INTEGER NOT NULL,
    data_dostawy DATE NOT NULL DEFAULT CURRENT_DATE,
    nr_faktury VARCHAR(50) UNIQUE,
    
    CONSTRAINT fk_producenci FOREIGN KEY (id_producenta) REFERENCES producenci(id_producenta) ON DELETE CASCADE
);

CREATE TABLE zamowienia (
    id_zamowienia SERIAL PRIMARY KEY,
    id_klienta INTEGER NOT NULL,
    data_zamowienia DATE NOT NULL DEFAULT CURRENT_DATE,
    nr_faktury VARCHAR(50) UNIQUE,
    
    CONSTRAINT fk_klienci FOREIGN KEY (id_klienta) REFERENCES klienci(id_klienta) ON DELETE CASCADE
);

CREATE TABLE magazyn (
    id_produktu INTEGER PRIMARY KEY,
    ilosc INTEGER NOT NULL CHECK (ilosc >= 0),
    
    CONSTRAINT fk_produkt FOREIGN KEY (id_produktu) REFERENCES produkty(id_produktu) ON DELETE CASCADE
);

CREATE TABLE dane_dostawy (
    id_dostawy INTEGER NOT NULL,
    id_produktu INTEGER NOT NULL,
    ilosc INTEGER NOT NULL CHECK (ilosc > 0),
    cena_zakupu DECIMAL(10,2) NOT NULL CHECK (cena_zakupu > 0),
    
    PRIMARY KEY (id_dostawy, id_produktu),
    CONSTRAINT fk_dostawy FOREIGN KEY (id_dostawy) REFERENCES dostawy(id_dostawy) ON DELETE CASCADE,
    CONSTRAINT fk_produkty FOREIGN KEY (id_produktu) REFERENCES produkty(id_produktu) ON DELETE CASCADE
);

CREATE TABLE dane_zamowienia (
    id_zamowienia INTEGER NOT NULL,
    id_produktu INTEGER NOT NULL,
    ilosc INTEGER NOT NULL CHECK (ilosc > 0),
    cena_zakupu DECIMAL(10,2) NOT NULL CHECK (cena_zakupu > 0),
    
    PRIMARY KEY (id_zamowienia, id_produktu),
    CONSTRAINT fk_zamowienia FOREIGN KEY (id_zamowienia) REFERENCES zamowienia(id_zamowienia) ON DELETE CASCADE,
    CONSTRAINT fk_produkty FOREIGN KEY (id_produktu) REFERENCES produkty(id_produktu) ON DELETE CASCADE
);

-- Ładowanie danych (COPY syntax)

